page {
  min-height: 100%;
  background: #f7f4ed;
  color: #2f2a23;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  line-height: 1.65;
}
.container { min-height: 100vh; padding: 24rpx 24rpx 72rpx; box-sizing: border-box; background: #f7f4ed; }
.hero { position: relative; overflow: hidden; margin-bottom: 24rpx; padding: 38rpx 34rpx; border-radius: 34rpx; color: #fff; background: linear-gradient(135deg, #28513a, #2c8a55); box-shadow: 0 20rpx 46rpx rgba(31, 93, 56, .20); }
.hero::after { content: ''; position: absolute; right: -60rpx; bottom: -90rpx; width: 260rpx; height: 260rpx; border-radius: 50%; background: rgba(255,255,255,.12); }
.hero-kicker,.hero-title,.hero-sub { position: relative; z-index: 1; }
.hero-kicker { font-size: 22rpx; font-weight: 900; letter-spacing: 3rpx; opacity: .82; }
.hero-title { margin-top: 8rpx; font-size: 50rpx; line-height: 1.12; font-weight: 900; }
.hero-sub { margin-top: 14rpx; max-width: 600rpx; font-size: 28rpx; opacity: .92; }
.card { margin-bottom: 24rpx; padding: 28rpx; border: 1rpx solid #e8dfd0; border-radius: 28rpx; background: #fffdf8; box-shadow: 0 12rpx 34rpx rgba(48, 42, 32, .07); box-sizing: border-box; }
.card-title { margin-bottom: 10rpx; color: #2f2a23; font-size: 34rpx; line-height: 1.35; font-weight: 900; }
.section-title { margin: 34rpx 4rpx 18rpx; font-size: 36rpx; line-height: 1.25; font-weight: 900; color: #2f2a23; }
.muted { color: #776f64; font-size: 26rpx; }
.badge { display: inline-block; margin-right: 8rpx; margin-bottom: 8rpx; padding: 6rpx 16rpx; border-radius: 999rpx; background: #e9f3eb; color: #1f5d38; font-size: 24rpx; font-weight: 800; }
.badge-warm { background: #fff3df; color: #9b5b16; }
button.btn,.btn { display: flex; align-items: center; justify-content: center; min-height: 84rpx; margin-top: 18rpx; padding: 0 28rpx; border-radius: 999rpx; background: #287a49; color: #fff; font-size: 30rpx; font-weight: 900; line-height: 84rpx; box-shadow: 0 12rpx 24rpx rgba(40,122,73,.18); }
button.btn::after { border: 0; }
.btn-secondary { background: #fff; color: #287a49; border: 1rpx solid #e8dfd0; box-shadow: none; }
.input { min-height: 82rpx; margin: 18rpx 0; padding: 0 22rpx; border: 1rpx solid #e8dfd0; border-radius: 20rpx; background: #fff; box-sizing: border-box; }
.ok,.bad { margin-top: 16rpx; padding: 18rpx 20rpx; border-radius: 20rpx; font-size: 27rpx; }
.ok { background: #e7f5e7; color: #1f5d38; }
.bad { background: #fae7e5; color: #8c2b25; }
.row { display: flex; gap: 18rpx; flex-wrap: wrap; }
.two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 18rpx; }
.soft-panel { padding: 20rpx; border-radius: 24rpx; background: #f5efe4; }
.green-panel { padding: 20rpx; border-radius: 24rpx; background: #eef6ea; }
.formula-box { margin: 14rpx 0; padding: 18rpx; border-radius: 20rpx; background: #eef6ea; color: #1f5d38; font-size: 30rpx; font-weight: 900; }
.relation-box { margin: 16rpx 0; padding: 16rpx; border-radius: 18rpx; background: #eef6ea; color: #1f5d38; font-weight: 800; }
.map-row { margin-top: 10rpx; color: #5a4532; }
.map-label { font-weight: 900; color: #2f2a23; }
