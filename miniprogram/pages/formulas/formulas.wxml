<view class="container formula-page">
  <view class="hero">
    <view class="hero-kicker">FORMULA</view>
    <view class="hero-title">核心概念速查</view>
    <view class="hero-sub">公式、例子、易错提醒。先会查，再会用。</view>
  </view>

  <block wx:for="{{list}}" wx:key="concept">
    <view class="card formula-card">
      <view>
        <text class="badge">{{item.module}}</text>
        <text class="badge badge-warm">{{item.level}}</text>
      </view>
      <view class="card-title">{{item.concept}}</view>
      <view class="formula-box">{{item.formula}}</view>
      <view class="muted">提醒：{{item.note}}</view>
    </view>
  </block>
</view>
