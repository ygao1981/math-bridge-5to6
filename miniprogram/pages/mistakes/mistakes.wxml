<view class="container">
  <view class="hero">
    <view class="hero-title">数学避坑指南</view>
    <view class="hero-sub">6 大模块，31 个高频坑。错题复盘时先看这里。</view>
  </view>

  <block wx:for="{{list}}" wx:key="title">
    <view class="card mistake-card">
      <view class="module-tag">{{item.module}}</view>
      <view class="card-title">{{index + 1}}. {{item.title}}</view>
      <view class="bad"><text class="label">错误示范：</text>{{item.wrong}}</view>
      <view class="why"><text class="label">为什么错：</text>{{item.why}}</view>
      <view class="ok"><text class="label">正确做法：</text>{{item.right}}</view>
      <view class="tip"><text class="label">口诀：</text>{{item.tip}}</view>
      <view class="practice"><text class="label">小练习：</text>{{item.practice}}</view>
    </view>
  </block>
</view>
