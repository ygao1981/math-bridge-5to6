.mistake-card { border-left: 8rpx solid #b7504a; }
.module-tag { display: inline-block; margin-bottom: 12rpx; padding: 6rpx 16rpx; border-radius: 999rpx; background: #fff3df; color: #9b5b16; font-size: 24rpx; font-weight: 700; }
.card-title { margin-bottom: 16rpx; }
.bad,.ok,.why,.tip,.practice { margin: 12rpx 0; padding: 14rpx 16rpx; border-radius: 16rpx; font-size: 28rpx; line-height: 1.55; }
.bad { background: #fae7e5; color: #8c2b25; }
.ok { background: #e7f5e7; color: #1f5d38; }
.why { background: #f5efe4; color: #5a4532; }
.tip { background: #eef6ea; color: #1f5d38; font-weight: 700; }
.practice { background: #fff7e8; color: #5a4532; }
.label { font-weight: 800; }
